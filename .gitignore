# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like the assets are installed.
/assets/node_modules/

# Ignore assets that are produced by build commands.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you run "mix ecto.dump" or "mix ecto.load", the
# SQL files will be generated in the /priv/repo/ directory.
/priv/repo/*.sql

# The config/*.secret.exs files contain secret keys.
/config/*.secret.exs

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
